{
  "name": "blog-editor",
  "version": "1.0.0",
  "description": "Desktop editor for managing the Astro blog content repository.",
  "author": "rain1andsnow2a",
  "private": true,
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:electron": "wait-on tcp:5177 && electron electron/main.mjs",
    "dev:renderer": "vite",
    "dev:web": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "vite build",
    "start": "electron electron/main.mjs",
    "clean:release": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$release = Resolve-Path -LiteralPath 'release' -ErrorAction SilentlyContinue; if (-not $release) { New-Item -ItemType Directory -Path 'release' | Out-Null; exit 0 }; Get-ChildItem -LiteralPath $release -Force -ErrorAction SilentlyContinue | ForEach-Object { Remove-Item -LiteralPath $_.FullName -Recurse -Force -ErrorAction Stop }\"",
    "pack": "npm run clean:release && npm run build && electron-builder --dir -c.win.signAndEditExecutable=false",
    "dist:portable": "npm run clean:release && npm run build && electron-builder --win portable --publish never --config.win.signAndEditExecutable=false",
    "dist:nsis": "npm run clean:release && npm run build && electron-builder --win nsis --publish never --config.win.signAndEditExecutable=false",
    "dist:win": "npm run clean:release && npm run build && electron-builder --win nsis portable --publish never -c.win.signAndEditExecutable=false"
  },
  "dependencies": {
    "@tiptap/core": "^2.6.0",
    "@tiptap/extension-code-block-lowlight": "^2.6.0",
    "@tiptap/extension-color": "^2.6.0",
    "@tiptap/extension-highlight": "^2.6.0",
    "@tiptap/extension-image": "^2.6.0",
    "@tiptap/extension-link": "^2.6.0",
    "@tiptap/extension-placeholder": "^2.6.0",
    "@tiptap/extension-table": "^2.6.0",
    "@tiptap/extension-table-cell": "^2.6.0",
    "@tiptap/extension-table-header": "^2.6.0",
    "@tiptap/extension-table-row": "^2.6.0",
    "@tiptap/extension-task-item": "^2.6.0",
    "@tiptap/extension-task-list": "^2.6.0",
    "@tiptap/extension-text-style": "^2.6.0",
    "@tiptap/extension-underline": "^2.6.0",
    "@tiptap/pm": "^2.6.0",
    "@tiptap/react": "^2.6.0",
    "@tiptap/starter-kit": "^2.6.0",
    "@types/katex": "^0.16.8",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "gray-matter": "^4.0.3",
    "katex": "^0.16.45",
    "lowlight": "^3.1.0",
    "lucide-react": "^0.462.0",
    "multer": "^1.4.5-lts.1",
    "octokit": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/turndown": "^5.0.5",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.rain1andsnow2a.blogeditor",
    "productName": "Blog Editor",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Blog Editor"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable-${arch}.${ext}"
    }
  }
}
